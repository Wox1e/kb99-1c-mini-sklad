Процедура ОбработкаПроведения(Отказ, Режим)
	
	Движения.ОстатокТоваров.Записывать = Истина;
	Движения.Продажи.Записывать = Истина;

	Для Каждого ТекСтрокаТовары Из Товары Цикл
		ЗапросПартий = Новый Запрос;
		ЗапросПартий.Текст = 
			"ВЫБРАТЬ
			|	Остатки.Партия КАК Партия,
			|	Остатки.КоличествоОстаток КАК Доступно,
			|	ВЫБОР
			|		КОГДА Остатки.КоличествоОстаток > 0
			|		ТОГДА Остатки.СуммаОстаток / Остатки.КоличествоОстаток
			|		ИНАЧЕ 0
			|	КОНЕЦ КАК СебестоимостьЕдиницы
			|ИЗ
			|	РегистрНакопления.ОстатокТоваров.Остатки(
			|		&ДатаРеализации,
			|		Товар = &Товар
			|	) КАК Остатки
			|ГДЕ
			|	Остатки.КоличествоОстаток > 0
			|
			|УПОРЯДОЧИТЬ ПО
			|	Партия";
		
		ЗапросПартий.УстановитьПараметр("ДатаРеализации", Дата);
		ЗапросПартий.УстановитьПараметр("Товар", ТекСтрокаТовары.Товар);
		
		ВыборкаПартий = ЗапросПартий.Выполнить().Выбрать();
		ОсталосьСписать = ТекСтрокаТовары.Количество;
		СуммаСебестоимости = 0;
		
		Пока ОсталосьСписать > 0 И ВыборкаПартий.Следующий() Цикл
			
			КСписанию = Мин(ОсталосьСписать, ВыборкаПартий.Доступно);
			
			ДвижениеОстаток = Движения.ОстатокТоваров.Добавить();
			ДвижениеОстаток.ВидДвижения = ВидДвиженияНакопления.Расход;
			ДвижениеОстаток.Период = Дата;
			ДвижениеОстаток.Товар = ТекСтрокаТовары.Товар;
			ДвижениеОстаток.Партия = ВыборкаПартий.Партия;
			ДвижениеОстаток.Количество = КСписанию;
			ДвижениеОстаток.Сумма = КСписанию * ВыборкаПартий.СебестоимостьЕдиницы;
			
			СуммаСебестоимости = СуммаСебестоимости + ДвижениеОстаток.Сумма;
			ОсталосьСписать = ОсталосьСписать - КСписанию;
			
		КонецЦикла;
		
		Если ОсталосьСписать > 0 Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Не хватает товара «" + ТекСтрокаТовары.Товар + 
			                  "» на складе. Не удалось списать: " + ОсталосьСписать + " шт.";
			Сообщение.Сообщить();
			Отказ = Истина;
			Возврат;
		КонецЕсли;
		
		ДвижениеПродажа = Движения.Продажи.Добавить();
		ДвижениеПродажа.Период = Дата;
		ДвижениеПродажа.Товар = ТекСтрокаТовары.Товар;
		ДвижениеПродажа.Количество = ТекСтрокаТовары.Количество;
		
		ДвижениеПродажа.СуммаПродажи = ТекСтрокаТовары.Количество * ТекСтрокаТовары.Цена;  
		ДвижениеПродажа.СуммаСебестоимости = СуммаСебестоимости;
		
	КонецЦикла;
	
КонецПроцедуры